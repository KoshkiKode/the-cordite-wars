  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  entitlements.plist — Hardened Runtime entitlements for Cordite Wars: Six Fronts
  Generated by generate_versions.py — do not edit directly.
  Used by: codesign --entitlements versions/macos/entitlements.plist
-->
<plist version="1.0">
<dict>
  <!-- Required by Mono/.NET JIT to write executable memory pages -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Disable library validation so Godot can load its plugins -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Network: multiplayer client connections -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Network: LAN listen server / host -->
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- User data: read/write saves in ~/Library/Application Support -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
