<?xml version="1.0" encoding="utf-8"?>
<!--
  AppxManifest.xml — MSIX package manifest for Cordite Wars: Six Fronts
  Version strings are kept in sync by bump-version.py.

  Publisher CN must exactly match the code-signing certificate subject.
  CI builds use a self-signed dev cert (CN=CorditeWarsTeam); the resulting
  MSIX can be sideloaded on any machine that trusts that cert.
  For Microsoft Store distribution replace Publisher with your EV cert subject.

  Build:
    makeappx pack /d msix_stage /p CorditeWars_X.Y.Z.msix
    signtool sign /fd SHA256 /n "CorditeWarsTeam" CorditeWars_X.Y.Z.msix
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <!-- Identity: Version must be 4-part (Major.Minor.Build.Revision). -->
  <Identity
    Name="KoshkiKode.CorditeWarsSixFronts"
    Publisher="CN=CorditeWarsTeam"
    Version="1.0.0.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Cordite Wars: Six Fronts</DisplayName>
    <PublisherDisplayName>Cordite Wars Team</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <!-- Windows 10 1809 (build 17763) minimum — matches the Inno Setup minimum. -->
  <Dependencies>
    <TargetDeviceFamily
      Name="Windows.Desktop"
      MinVersion="1.0.0.0"
      MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application
      Id="CorditeWars"
      Executable="CorditeWars.exe"
      EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Cordite Wars: Six Fronts"
        Description="A cross-platform real-time strategy game inspired by Command &amp; Conquer and Tempest Rising."
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for outbound internet (multiplayer). -->
    <Capability Name="internetClient" />
    <!-- Required for LAN hosting. -->
    <Capability Name="privateNetworkClientServer" />
    <!-- Required by the Godot engine (unpackaged Win32 binary). -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

</Package>
