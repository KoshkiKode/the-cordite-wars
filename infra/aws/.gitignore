# Local Terraform state and overrides — never commit these.
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Lambda build artifacts (generated by `archive_file`).
.build/

# Python bytecode caches.
lambda/**/__pycache__/
lambda/**/*.pyc
